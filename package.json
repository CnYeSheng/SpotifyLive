{
  "name": "spotify-lyrics-player",
  "version": "2.0.0",
  "description": "Enhanced Spotify lyrics player with real-time sync and advanced controls",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "tsx watch src/server.ts",
    "dev": "concurrently \"pnpm run dev:frontend\" \"pnpm run dev:backend\"",
    "build:frontend": "vite build",
    "build:backend": "tsc",
    "build": "pnpm run build:frontend && pnpm run build:backend",
    "preview": "vite preview",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue",
    "test": "vitest"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "@vercel/kv": "^1.0.1",
    "vue": "^3.3.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "eslint": "^8.54.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "keywords": [
    "spotify",
    "lyrics",
    "music",
    "web-app",
    "vercel",
    "real-time",
    "vue",
    "typescript"
  ],
  "author": "",
  "license": "MIT"
}
