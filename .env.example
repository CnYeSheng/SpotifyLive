# Spotify API Credentials
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
REDIRECT_URI=https://live.cyss.us.eu.org/callback
PORT=3000
DOMAIN=live.cyss.us.eu.org

# Vercel KV Database
# Get these from https://vercel.com/dashboard/stores
KV_REST_API_URL=your_kv_rest_api_url
KV_REST_API_TOKEN=your_kv_rest_api_token
KV_REST_API_READ_ONLY_TOKEN=your_kv_read_only_token

# Local Database Configuration (Optional - for persistent lyrics/settings)
# Choose ONE of the following DB_TYPEs: postgres, mysql, mongo
# If not set, it will default to in-memory storage (reset on restart)
DB_TYPE=postgres
# DATABASE_URL examples:
# Postgres: postgres://user:pass@localhost:5432/spotify_lyrics
# MySQL: mysql://user:pass@localhost:3306/spotify_lyrics
# Mongo: mongodb://localhost:27017/spotify_lyrics
DATABASE_URL=your_database_connection_string

# Redis Configuration (Optional - for caching)
USE_REDIS=true
REDIS_URL=redis://localhost:6379
